# OpenClaw AI Agent 环境变量配置

# ========================
# 数据库配置
# ========================
DATABASE_URL=postgresql://postgres:openclaw@localhost:5432/openclaw_db

# ========================
# AI 模型 API Keys
# ========================
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# ========================
# 代理池配置 (Proxy)
# ========================
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST=

# ========================
# 应用基础配置
# ========================
ENVIRONMENT=development
DEBUG=True
