# OpenClaw AI Agent - Environment Configuration
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env to version control!

# ========================
# 数据库配置
# ========================
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:openclaw@localhost:5432/openclaw_db

# ========================
# JWT 认证配置 (IMPORTANT: Change this in production!)
# ========================
# Secret key for JWT token signing. Use a long random string in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# ========================
# AI 模型 API Keys
# ========================
# OpenAI API Key (for GPT models)
OPENAI_API_KEY=

# OpenRouter API Key (for accessing various LLMs)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional OpenRouter model override for marketing copy and pipeline generation.
OPENROUTER_MARKETING_MODEL=qwen/qwen3-30b-a3b-instruct-2507
# Comma-separated fallback chain for provider routing or policy failures.
OPENROUTER_MARKETING_FALLBACK_MODELS=google/gemini-2.5-flash,google/gemini-2.5-flash-lite,openai/gpt-4o-mini

# ========================
# 代理池配置 (Optional)
# ========================
# Proxy credentials and host for scraping
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST=
# Optional full proxy URL used by the workbench status check.
SCRAPER_PROXY=

# ========================
# Chrome 用户数据目录 (Optional, for persistent sessions)
# ========================
# Path to Chrome user data directory for maintaining login sessions
# CHROME_USER_DATA_DIR=C:/Users/YourUser/AppData/Local/Google/Chrome/User Data

# ========================
# 应用基础配置
# ========================
# Environment: development | production
ENVIRONMENT=development

# Enable debug mode (disable in production!)
DEBUG=True

# Generate fictional leads only for demos. Keep disabled for real workspaces.
DEMO_MODE=false

# Single-machine worker capacity.
MAX_CONCURRENT_TASKS=5
MAX_BROWSER_INSTANCES=3

# Allowed CORS origins (comma-separated)
# For production, specify exact domains: https://yourapp.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ========================
# 任务队列配置 (Optional, for distributed deployment)
# ========================
# Redis URL for Celery broker (if using task queue)
# REDIS_URL=redis://localhost:6379/0

# ========================
# LinkedIn 爬虫配置 (Optional)
# ========================
# LinkedIn cookies JSON for authentication
# LINKEDIN_COOKIES=

# ========================
# Facebook GraphQL 配置 (Optional)
# ========================
# Facebook Access Token for GraphQL API
# FACEBOOK_ACCESS_TOKEN=
