{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "description": "Python 代码格式化检查",
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && python -m black --check --diff .",
            "description": "检查 Python 格式 (Black)"
          },
          {
            "type": "command",
            "command": "cd backend && python -m ruff check --fix .",
            "description": "Python Linting (Ruff)"
          }
        ]
      },
      {
        "matcher": "Write",
        "description": "FastAPI backend 文件检查",
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && python -m mypy api/ --ignore-missing-imports 2>/dev/null | head -20",
            "description": "Python 类型检查 (mypy)"
          }
        ]
      },
      {
        "matcher": "Write",
        "description": "React 前端文件检查",
        "hooks": [
          {
            "type": "command",
            "command": "cd frontend && npx eslint src/ --max-warnings 0 --quiet 2>/dev/null | head -10",
            "description": "ESLint 检查 (仅警告)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "description": "保护敏感文件不被意外修改",
        "hooks": [
          {
            "type": "block",
            "blockPaths": [
              ".env",
              "**/*.env*",
              "**/credentials.json",
              "**/*secret*",
              "**/*.key",
              "**/*password*"
            ],
            "description": "阻止修改敏感配置文件"
          }
        ]
      },
      {
        "matcher": "Write",
        "description": "防止提交调试代码",
        "hooks": [
          {
            "type": "block",
            "blockPaths": [
              "**/TODO_FAKE*",
              "**/*DEBUG*",
              "**/test_should_fail*"
            ],
            "description": "阻止写入测试用占位符"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "ToolUse",
        "description": "权限提升提醒",
        "hooks": [
          {
            "type": "notify",
            "title": "OpenClaw AI Agent",
            "body": "检测到需要额外权限的操作"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__pencil",
      "mcp__plugin_everything-claude-code_context7",
      "mcp__plugin_everything-claude-code_github",
      "mcp__plugin_everything-claude-code_playwright"
    ]
  }
}
