{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && python -m black --check --diff ."
          },
          {
            "type": "command",
            "command": "cd backend && python -m ruff check --fix ."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && python -m mypy api/ --ignore-missing-imports"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd frontend && npx eslint src/ --max-warnings 0 --quiet"
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo Checking sensitive files..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo Checking debug patterns..."
          }
        ]
      }
    ],

    "Notification": [
      {
        "matcher": "ToolUse",
        "hooks": [
          {
            "type": "command",
            "command": "echo OpenClaw Agent: privileged action detected"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "mcp__pencil",
      "mcp__plugin_everything-claude-code_context7",
      "mcp__plugin_everything-claude-code_github",
      "mcp__plugin_everything-claude-code_playwright"
    ]
  }
}