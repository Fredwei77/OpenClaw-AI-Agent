{
  "name": "openclaw-ai-agent",
  "version": "1.0.0",
  "description": "OpenClaw AI - Cross-Border Ecommerce AI Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "build": "npm run dist"
  },
  "author": "OpenClaw",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.openclaw.agent",
    "productName": "OpenClaw AI",
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../frontend/dist",
        "to": "www"
      },
      {
        "from": "../../backend",
        "to": "backend"
      },
      {
        "from": "../../agents",
        "to": "agents"
      },
      {
        "from": "../../browser_cluster",
        "to": "browser_cluster"
      },
      {
        "from": "../../database",
        "to": "database"
      },
      {
        "from": "../../plugins",
        "to": "plugins"
      },
      {
        "from": "../../.env",
        "to": ".env"
      }
    ]
  }
}
